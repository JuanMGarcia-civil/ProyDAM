{
  "openapi": "3.0.0",
  "info": {
    "title": "API ProyectoFinal",
    "version": "1.0.0",
    "description": "API en Flask para gestionar proyectos, subir ficheros y generar gráficas"
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "paths": {
    "/proyects/{id}": {
      "delete": {
        "summary": "Elimina un proyecto y sus ficheros",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "1"
          }
        ],
        "responses": {
          "200": {
            "description": "Proyecto eliminado"
          }
        }
      }
    },
    "/proyects/{id}/upload": {
      "post": {
        "summary": "Sube una carpeta de ficheros al proyecto",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "1"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "files": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" }
                  }
                },
                "required": ["files"]
              },
              "encoding": {
                "files": {
                  "contentType": "application/octet-stream"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ficheros subidos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "files": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "count": { "type": "integer" }
                  }
                },
                "examples": {
                  "subida-ok": {
                    "summary": "Carpeta subida con varios ficheros",
                    "value": {
                      "id": "1",
                      "files": [
                        "plot_config.xlsx",
                        "subcarpeta/datos.csv"
                      ],
                      "count": 2
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/proyects/{id}/execute_plots": {
      "post": {
        "summary": "Genera las gráficas y el informe del proyecto",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "1"
          }
        ],
        "responses": {
          "200": {
            "description": "Registro de las gráficas generadas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "output_dir": { "type": "string" },
                    "plots": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Sheet": { "type": "string" },
                          "File Name": { "type": "string" },
                          "Description": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "plots-generados": {
                    "summary": "Gráficas generadas a partir de plot_config.xlsx",
                    "value": {
                      "id": "1",
                      "output_dir": "/app/uploads/1/Plots",
                      "plots": [
                        {
                          "Sheet": "TypicalSection",
                          "File Name": "TypicalSection_1.png",
                          "Description": "Interaction diagram"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/uploads/{id}": {
      "get": {
        "summary": "Devuelve el informe final del proyecto en formato Markdown",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "1"
          }
        ],
        "responses": {
          "200": {
            "description": "Contenido del fichero Final_Report.md",
            "content": {
              "text/markdown": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/uploads/{id}/Plots/media/{filename}": {
      "get": {
        "summary": "Sirve una imagen generada del informe",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "1"
          },
          {
            "name": "filename",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "TypicalSection_1.png"
          }
        ],
        "responses": {
          "200": {
            "description": "Imagen solicitada",
            "content": {
              "image/png": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    },
    "/uploads/{id}/Plots/Final_Report.docx": {
      "get": {
        "summary": "Descarga el informe final del proyecto en formato Word",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "1"
          }
        ],
        "responses": {
          "200": {
            "description": "Fichero Final_Report.docx",
            "content": {
              "application/vnd.openxmlformats-officedocument.wordprocessingml.document": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    }
  }
}
