{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Suma",
    "version": "1.0.0",
    "description": "API simple en Flask para sumar dos números"
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "paths": {
    "/sumar": {
      "post": {
        "summary": "Suma dos números",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "a": {
                    "type": "number",
                    "example": 10
                  },
                  "b": {
                    "type": "number",
                    "example": 5
                  }
                },
                "required": ["a", "b"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resultado de la suma",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "a": {
                      "type": "number"
                    },
                    "b": {
                      "type": "number"
                    },
                    "resultado": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
