# Firebase Web SDK config — copy this file to `.env` and fill in your values.
# Get them from: Firebase Console → ⚙️ Project Settings → General → Your apps → Web app → SDK setup and configuration
# These values are public (Firebase Auth is secured by domain allowlist + security rules, not by hiding these keys),
# but we keep them out of git anyway so different environments (dev/prod) can use different projects.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
